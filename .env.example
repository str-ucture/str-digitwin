# ─────────────────────────────────────────────────────────────────
# Frontend (exposed to browser via Vite — prefix with VITE_)
# ─────────────────────────────────────────────────────────────────

# Mapbox GL JS access token — create at https://account.mapbox.com
# IMPORTANT: restrict this token to your GitHub Pages domain in the Mapbox dashboard
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiLi4uIn0...

# Supabase project URL (Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Settings → API) — safe to expose in frontend
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Base path for GitHub Pages.
# Local dev: leave as /
# GitHub org Pages: set to /your-repo-name/ (e.g. /str-digitwin/)
# Also add as VITE_BASE_PATH secret in GitHub Actions (Settings → Secrets)
VITE_BASE_PATH=/

# ─────────────────────────────────────────────────────────────────
# Backend scripts only (never sent to browser)
# ─────────────────────────────────────────────────────────────────

# Supabase URL for backend scripts (seed.ts etc.)
# Online:  same as VITE_SUPABASE_URL above (e.g. https://abc.supabase.co)
# Local:   http://127.0.0.1:54321 (printed by `npm run supabase:start`)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — used by seed script, never expose to frontend
# Online:  Settings → API → service_role key
# Local:   printed by `npm run supabase:start`
# WARNING: never commit this value
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin user credentials for the create-admin-user.ts script
# WARNING: never commit this value
ADMIN_EMAIL=admin@yourproject.com
ADMIN_PASSWORD=your-secure-password-here

# ─────────────────────────────────────────────────────────────────
# Supabase Edge Function secrets (set via CLI, never in .env files)
# These are stored server-side only and never reach the browser.
# ─────────────────────────────────────────────────────────────────

# Google Gemini API key — used by the scrape-project edge function locally.
# Get from: https://aistudio.google.com/app/apikey
# For production (hosted Supabase): run `npm run supabase:secrets` to push it once.
# GEMINI_API_KEY=AIzaSy...

# When running edge functions locally (`npm run functions:serve`), set this so the
# frontend calls localhost instead of the hosted Supabase function.
# Comment out / remove for production deployments.
# VITE_FUNCTIONS_URL=http://localhost:54321/functions/v1

# Mapbox secret token for server-side geocoding (no domain restrictions needed)
# Create a SEPARATE token from VITE_MAPBOX_TOKEN at https://account.mapbox.com
# Set with: supabase secrets set MAPBOX_TOKEN=sk.eyJ1...
# MAPBOX_TOKEN=sk.eyJ1...
