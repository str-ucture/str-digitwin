.env
.env.local
.env.production
.env.development
.env.*.local
# Nested (e.g. backend/.env)
**/.env
**/.env.local
**/.env.production
**/.env.development
**/.env.*.local

# ── AI tooling (Claude Code) — local config, not for the repo ────────────────
.claude/

# ── Supabase local state (auto-generated) ────────────────────────────────────
supabase/.temp/
supabase/.branches/
supabase/

# ── Certificates & private keys ──────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
*.pfx

