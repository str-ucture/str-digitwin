.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
