# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
backend/dist/

# ── Environment & secrets — NEVER commit real keys ───────────────────────────
