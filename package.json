    "@react-three/fiber": "^8.18.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-virtual": "^3.13.24",
    "express": "^5.2.1",
    "i18next": "^23.15.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^1.14.0",
    "mapbox-gl": "^3.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.0",
