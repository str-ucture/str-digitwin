    "supabase:types": "supabase gen types typescript --local > src/types/database.ts",
    "seed": "tsx backend/src/scripts/seed.ts",
    "create-admin": "tsx backend/src/scripts/create-admin-user.ts",
    "supabase:secrets": "tsx backend/src/scripts/push-secrets.ts",
    "functions:serve": "supabase functions serve --env-file .env.local"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.3.0",
